{
  "name": "@gamepark/game-template-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "The user interface of Game Template adaptation for Game Park",
  "author": "Romain Fromi <romain@game-park.com> (https://game-park.com/)",
  "license": "ISC",
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "upload-sourcemaps": "datadog-ci sourcemaps upload dist/assets --service=game-template --release-version=$npm_package_version --minified-path-prefix=/assets/",
    "sync": "npx rimraf dist/assets/*.map && rclone sync dist game-template:game-template.game-park.com --progress --s3-acl=public-read",
    "deploy": "yarn build && node -e \"if(process.env.DATADOG_API_KEY){require('child_process').execSync('yarn upload-sourcemaps',{stdio:'inherit'})}\" && yarn sync"
  },
  "dependencies": {
    "@dnd-kit/core": "~6.3.1",
    "@emotion/react": "^11.14.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@gamepark/react-game": "~7.7.16",
    "@gamepark/rules-api": "~7.6.3",
    "es-toolkit": "^1.45.1",
    "i18next": "^25.10.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.6.6",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-imagetools": "^10.0.0",
    "vitest": "^4.1.4"
  }
}
